{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"],
      "@styles/*": ["src/styles/*"],
      "@public/*": ["public/*"],
      "types/*": ["src/types/*"]
    },
    "allowJs": true,
    "strict": false,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "noImplicitAny": false
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules", ".next", ".vercel"]
}
